# Countdown Timer app — copy to .env and fill in values.
# Many of these are set automatically when you run `shopify app config link` or `shopify app dev`;
# you can override them here.

# From Shopify Partners (App setup) or CLI link:
# SHOPIFY_API_KEY=your_api_key
# SHOPIFY_API_SECRET=your_api_secret

# MongoDB connection (required). Use local MongoDB or MongoDB Atlas.
# MONGODB_URI=mongodb://localhost:27017/countdown-timer
# Or: DATABASE_URL=mongodb+srv://user:pass@cluster.mongodb.net/dbname

# Optional — defaults used if unset:
# NODE_ENV=development
# BACKEND_PORT=3000
# PORT=3000
