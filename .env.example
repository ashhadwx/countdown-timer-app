# Countdown Timer app — copy to .env and fill in values.
# NEVER commit real keys. .env is gitignored; only .env.example is in the repo.

# Shopify (from Partners → App setup, or set by `shopify app config link` / `shopify app dev`)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# Match shopify.app.toml access_scopes
SCOPES=read_products,write_app_proxy
SHOP=

# App URL the CLI / OAuth use (host name only is derived). `shopify app dev` sets HOST.
# For manual `cd server && npm run dev`, set e.g. https://your-tunnel.ngrok-free.app or SHOPIFY_APP_URL.
# HOST=
# SHOPIFY_APP_URL=

# MongoDB (required). Local or Atlas URI.
MONGODB_URI=

# Optional — defaults used if unset
PORT=3000
