# Countdown Timer app — copy to .env and fill in values.
# NEVER commit real keys. .env is gitignored; only .env.example is in the repo.

# Shopify (from Partners → App setup, or set by `shopify app config link` / `shopify app dev`)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=
SHOP=

# MongoDB (required). Local or Atlas URI.
MONGODB_URI=

# Optional — defaults used if unset
PORT=3000
