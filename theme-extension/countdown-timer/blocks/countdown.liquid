{% comment %}
  Countdown Timer app block. Add to a product section in the theme editor.
  Passes shop and product GID to the widget; widget fetches timer from app API.
  If the widget does not load (no timer or App Proxy not set), a short hint is shown after a delay.
{% endcomment %}
{% if request.design_mode %}
  <div class="countdown-timer-block" style="min-height: 60px; background: #f5f5f5; padding: 12px; border-radius: 4px;">
    <p style="margin: 0 0 6px 0; color: #666;">Countdown Timer — add to product section.</p>
    <p style="margin: 0; font-size: 12px; color: #888;">Use the eye icon to preview on the storefront. You need an active timer in the app and App Proxy (<code>/apps/countdown</code>) configured.</p>
  </div>
{% elsif product %}
  {% assign product_gid = 'gid://shopify/Product/' | append: product.id %}
  <div
    id="countdown-timer-root"
    class="countdown-timer-block"
    data-shop="{{ shop.permanent_domain }}"
    data-product-id="{{ product_gid }}"
    data-api-root="{{ block.settings.api_root | default: '' }}"
    style="min-height: 0;"
  >
    <noscript>
      <p style="margin: 0; padding: 8px 0; font-size: 13px; color: #666;">Enable JavaScript to see the countdown.</p>
    </noscript>
  </div>
  <script>
    window.__COUNTDOWN_TIMER_CONFIG__ = {
      shop: {{ shop.permanent_domain | json }},
      productId: {{ product_gid | json }},
      collectionIds: [{% for col in product.collections %}{{ 'gid://shopify/Collection/' | append: col.id | json }}{% unless forloop.last %},{% endunless %}{% endfor %}],
      apiRoot: {{ block.settings.api_root | default: '' | json }}
    };
  </script>
  <script src="{{ 'countdown-widget.js' | asset_url }}" defer></script>
  <script>
    (function() {
      var root = document.getElementById('countdown-timer-root');
      if (!root) return;
      setTimeout(function() {
        if (root.querySelector('.countdown-timer-widget') || root.querySelector('.countdown-timer-widget--ended')) return;
        var placeholder = root.querySelector('.countdown-timer-fallback');
        if (placeholder) return;
        var p = document.createElement('p');
        p.className = 'countdown-timer-fallback';
        p.setAttribute('aria-hidden', 'true');
        p.style.cssText = 'margin:0;padding:8px 0;font-size:13px;color:#888;';
        var isPreview = typeof window !== 'undefined' && /shopifypreview\.com$/i.test(window.location.hostname || '');
        p.textContent = isPreview
          ? 'Countdown may not load in theme preview. Open your storefront in a new tab to see the timer. Ensure App Proxy (\u201c/apps/countdown\u201d) is set in Partners.'
          : 'Countdown will appear here when you have an active timer. Check the Countdown Timer app and ensure App Proxy (\u201c/apps/countdown\u201d) is set in Partners.';
        root.appendChild(p);
      }, 2500);
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "Countdown Timer",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "api_root",
      "label": "App API root (optional)",
      "info": "Leave blank to use same-origin /apps/countdown. Set to full app URL if using custom domain."
    }
  ]
}
{% endschema %}
