# Environment Configuration
.env
.env.*
!.env.example

# Dependency directory
node_modules

# Test coverage directory
coverage

# Ignore Apple macOS Desktop Services Store
.DS_Store

# Logs
logs
*.log

# ngrok tunnel file
config/tunnel.pid

# vite build output
dist/

# Theme extension build output
theme-extension/*/build

# Node library SQLite database
server/database.sqlite

# Ignore shopify files created during app dev
.shopify/*
.shopify.lock

# App-specific config from "shopify app config link" (client runs link for their app)
shopify.app.*.toml
